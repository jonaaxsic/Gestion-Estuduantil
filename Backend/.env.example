# ===========================================
# Variables de Entorno - Backend Django
# COPIA ESTE ARCHIVO COMO .env Y COMPLETA LOS VALORES
# ===========================================

# ===========================================
# SEGURIDAD
# ===========================================
SECRET_KEY=tu-clave-secreta-aqui-genera-una-segura
DEBUG=False

# Dominios permitidos (separados por coma)
# Para Cloudflare Pages: tu-dominio.pages.dev,tu-dominio.com
ALLOWED_HOSTS=*

# ===========================================
# MONGODB ATLAS
# ===========================================
# Opción 1: URI completa (recomendado)
MONGO_URI=mongodb+srv://jonaaxsic:Diegosalvador15@main-database.rpaamyh.mongodb.net/?appName=Main-Database

# Opción 2: Variables separadas (alternativo)
# MONGO_USER=jonaaxsic
# MONGO_PASSWORD=Diegosalvador15$
# MONGO_HOST=main-database.rpaamyh.mongodb.net
# MONGO_DB_NAME=App_estudiantil

# ===========================================
# PUERTO (No cambiar)
# ===========================================
PORT=8000
